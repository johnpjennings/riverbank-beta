    "appallingRelative": {
      "name": "Ezra-Nehemiah Ogle",
      "titleOrHonorific": "Mr.",
      "sort": "Lizard",
      "pronouns": "he/him",
      "age": "elderly",
      "relationship": "very old uncle",
      "whichSide": "mother's side",
      "particulars": {
        "1": "At death's door, or so they claim",
        "2": "Batty",
        "3": "Quarrelsome"
      }
    },
    "greatestWeapon": "Threatens to come and stay. Sometimes they do. Also, Wim is dependent on Uncle Ogle, so he might cut off Wim's allowance.",
    "dragYou": "Their bedside. They are sure they are dying, and you must come to them At Once to hear their lingering last words. This may be a sincere request, but it's far more likely to be a cunning ruse.",
    "homeDescription": "Uncle Ogle lives in the mostly Human spa town of Bath, where he has a nice rowhouse, but he only uses two rooms on the main floor.",
    "petsCommunityInterests": "Uncle Ogle is an ancient and very warty-looking lizard. He likes to peel out of all of his clothes and wander the public gardens making noises he says are lizard language. If he were a character, he'd be approaching Absolute Animality. He argues about everything.",
    "home": {
      "name": "Ye Nook",
      "type": "upstairs flat from a ground-story shopfront",
      "size": "four rooms",
      "location": "just east of the Chestnut",
      "housemates": "none",
      "heart": "His comfy leather chair, ottoman, and table in front of the fireplace in the parlor.",
      "description": "Two-storied house with a ground-story shopfront. Georgian structure of stone, even the gabled roofs. The shopfront has been expanded with a huge bay window. A row of ornamental hedges extends for some yards to either side of the shop, sheltering the impressive herb garden laid out according to Italian principles. Upstairs is a comfortable, small flat decorated with the rich colors and flowing lines of Art Nouveau."
    },
    "pet": {
      "hasPet": true,
      "name": "Jam-Jar",
      "species": "Cockchafer Beetle",
      "notes": "3-4 inches long. A chunky and clumsy, but pleasant-looking beetle with fanlike antennae, chestnut-brown wing covers, and a black body. Flying. All beetles can fly.\n\nBuzz. Whenever the GM thinks something has risen to the level of bothering a cockchafer, roll 1d6; on a 1-2, the beetle begins emitting a deafening buzz and does not stop until it is placated or removed from the area."
    },
    "vehicle": {
      "hasVehicle": true,
      "types": {
        "bicycle": false,
        "motorcycle": false,
        "rowingBoat": false,
        "sailboat": false,
        "other": true,
        "otherText": "other"
      },
      "details": "Details"
    },
    "souvenirs": {
      "display": "In a neat row on the wardrobe in the bedroom.",
      "items": "",
      "tokens": ""
    },
    "seasonalReckoning": "Personal goals, practical goals, and timeframes.",
    "otherNotes": "Debonair and elegant, Wim is a very attractive common Lizard with brown, tan, and cream speckles and stripes. He's a little dressier than most in the area because of his Town connections. He prefers proper tweed suits that bring out his shiny black eyes. He collects old china. Clothing, hobbies, objects of desire, contents of your pockets, etc.",
    "otherFamilyAndFriends": "Wim loves Town and has many friends there, some of whom come for visits when they need to get away from the bustle of the big city. He is a member of the Junior Bluebottle, a private club in Town, and often wears their special club waistcoat.",
    "temporaryModifiers": "Ongoing side effects, Sense and Charm A/P adjustments etc."
  },
