<form class="{{cssClass}} {{actor.type}} riverbank-sheet" autocomplete="off">
  <section class="riverbank-statblock">
    <section class="rb-column rb-left">
      <section class="rb-panel rb-top-id {{#if isModernSheet}}rb-top-id--modern{{/if}}" data-sort-drop-zone="true">
        {{#if isModernSheet}}
          <div class="rb-top-id-modern">
            <div class="rb-token-art">
              <img
                class="rb-token-art__image"
                src="{{actor.prototypeToken.texture.src}}"
                data-edit="prototypeToken.texture.src"
                title="{{actor.name}} Token"
              />
            </div>
            <div class="rb-top-id-modern__fields">
              <div class="rb-row rb-top-row">
                <label>Name</label>
                <input type="text" name="name" value="{{actor.name}}" />
                <label>Player</label>
                <input type="text" name="system.profile.player" value="{{system.profile.player}}" />
              </div>
              <div class="rb-row rb-meta-row rb-meta-row--modern-id">
                <label>Title</label>
                <input type="text" name="system.profile.titleOrHonorific" value="{{system.profile.titleOrHonorific}}" placeholder="title/honorific" />
                <label>Pronouns</label>
                <input type="text" name="system.profile.pronouns" value="{{system.profile.pronouns}}" />
                <label>Age</label>
                <input type="text" name="system.profile.age" value="{{system.profile.age}}" />
              </div>
              <div class="rb-row rb-meta-row rb-meta-row--modern-id">
                <label>Sort</label>
                <input type="text" name="system.profile.sort" value="{{system.profile.sort}}" data-sort-drop-zone="true" />
                <label>Size</label>
                <input type="text" name="system.profile.size" value="{{system.profile.size}}" data-sort-drop-zone="true" />
              </div>
              <div class="rb-row rb-meta-row rb-meta-row--modern-id">
                <label>Best Time</label>
                <input type="text" name="system.profile.bestTimeOfDay" value="{{system.profile.bestTimeOfDay}}" data-sort-drop-zone="true" />
                <label>Sociability</label>
                <input type="text" name="system.profile.sociability" value="{{system.profile.sociability}}" data-sort-drop-zone="true" />
              </div>
            </div>
          </div>
        {{else}}
          <div class="rb-row rb-top-row">
            <label>Name</label>
            <input type="text" name="name" value="{{actor.name}}" />
            <label>Player</label>
            <input type="text" value="{{playerDisplay}}" readonly />
          </div>
          <div class="rb-row rb-subnote-row">
            <span></span>
            <input type="text" name="system.profile.titleOrHonorific" value="{{system.profile.titleOrHonorific}}" placeholder="title/honorific" />
          </div>
          <div class="rb-row rb-meta-row">
            <label>Sort</label>
            <input type="text" name="system.profile.sort" value="{{system.profile.sort}}" data-sort-drop-zone="true" />
            <label>Pronouns</label>
            <input type="text" name="system.profile.pronouns" value="{{system.profile.pronouns}}" />
            <label>Size</label>
            <input type="text" name="system.profile.size" value="{{system.profile.size}}" data-sort-drop-zone="true" />
          </div>
          <div class="rb-row rb-meta-row">
            <label>Age</label>
            <input type="text" name="system.profile.age" value="{{system.profile.age}}" />
            <label>Best Time of the Day</label>
            <input type="text" name="system.profile.bestTimeOfDay" value="{{system.profile.bestTimeOfDay}}" data-sort-drop-zone="true" />
            <label>Sociability</label>
            <input type="text" name="system.profile.sociability" value="{{system.profile.sociability}}" data-sort-drop-zone="true" />
          </div>
        {{/if}}
      </section>

      <section class="rb-panel rb-animality-poetry">
        <h3>Animality / Poetry Range</h3>
        <div class="rb-ap-chart">
          <span class="rb-ap-side-stack" aria-hidden="true">
            <span class="rb-ap-side">-</span>
            <i class="fas fa-cow rb-ap-side-icon" title="Animality"></i>
          </span>
          <div class="rb-ap-main">
            <div class="rb-ap-current-penalties" data-ap-penalties aria-hidden="true"></div>
            <input
              class="rb-ap-slider"
              type="range"
              name="system.animalityPoetryRange"
              value="{{system.animalityPoetryRange}}"
              min="-8"
              max="8"
              step="1"
              data-dtype="Number"
            />
            <div class="rb-ap-ticks" aria-hidden="true">
              <span class="rb-ap-tick"><i></i><small>-8</small></span>
              <span class="rb-ap-tick"><i></i><small>-7</small></span>
              <span class="rb-ap-tick"><i></i><small>-6</small></span>
              <span class="rb-ap-tick"><i></i><small>-5</small></span>
              <span class="rb-ap-tick"><i></i><small>-4</small></span>
              <span class="rb-ap-tick"><i></i><small>-3</small></span>
              <span class="rb-ap-tick"><i></i><small>-2</small></span>
              <span class="rb-ap-tick"><i></i><small>-1</small></span>
              <span class="rb-ap-tick"><i></i><small>0</small></span>
              <span class="rb-ap-tick"><i></i><small>+1</small></span>
              <span class="rb-ap-tick"><i></i><small>+2</small></span>
              <span class="rb-ap-tick"><i></i><small>+3</small></span>
              <span class="rb-ap-tick"><i></i><small>+4</small></span>
              <span class="rb-ap-tick"><i></i><small>+5</small></span>
              <span class="rb-ap-tick"><i></i><small>+6</small></span>
              <span class="rb-ap-tick"><i></i><small>+7</small></span>
              <span class="rb-ap-tick"><i></i><small>+8</small></span>
            </div>
          </div>
          <span class="rb-ap-side-stack" aria-hidden="true">
            <span class="rb-ap-side">+</span>
            <i class="fas fa-palette rb-ap-side-icon" title="Poetry"></i>
          </span>
        </div>
      </section>

      <section class="rb-panel rb-stat-table" data-sort-drop-zone="true">
        <button type="button" class="rb-stat-utility rollable" data-roll-for-stat="true">
          <i class="fas fa-dice-six" aria-hidden="true"></i>
          <span>Roll for Stat</span>
        </button>
        <div class="rb-stat-header">
          <span></span>
          <span>sort stat</span>
          <span></span>
          <span>peculiarities</span>
          <span></span>
          <span>elective points</span>
          <span></span>
          <span>final stat</span>
          <span></span>
        </div>
        <div class="rb-stat-row">
          <label>CHARM</label>
          <input type="text" name="system.stats.charm.sort" value="{{system.stats.charm.sort}}" data-dtype="Number" data-sort-drop-zone="true" />
          <span class="rb-stat-op">&plusmn;</span>
          <input type="text" name="system.stats.charm.peculiarity" value="{{system.stats.charm.peculiarity}}" data-dtype="Number" />
          <span class="rb-stat-op">+</span>
          <input type="text" name="system.stats.charm.elective" value="{{system.stats.charm.elective}}" data-dtype="Number" />
          <span class="rb-stat-op">=</span>
          <input
            type="text"
            class="rollable rb-stat-roll-target"
            name="system.stats.charm.final"
            value="{{system.stats.charm.final}}"
            data-dtype="Number"
            data-roll="1d6 + @stats.charm.final"
            data-label="Charm"
            data-stat="charm"
            readonly
          />
          <span class="rollable rb-stat-roll-target" data-roll="1d6 + @stats.charm.final" data-label="Charm" data-stat="charm">CHARM</span>
        </div>
        <div class="rb-stat-row">
          <label>INTREPIDITY</label>
          <input type="text" name="system.stats.intrepidity.sort" value="{{system.stats.intrepidity.sort}}" data-dtype="Number" data-sort-drop-zone="true" />
          <span class="rb-stat-op">&plusmn;</span>
          <input type="text" name="system.stats.intrepidity.peculiarity" value="{{system.stats.intrepidity.peculiarity}}" data-dtype="Number" />
          <span class="rb-stat-op">+</span>
          <input type="text" name="system.stats.intrepidity.elective" value="{{system.stats.intrepidity.elective}}" data-dtype="Number" />
          <span class="rb-stat-op">=</span>
          <input
            type="text"
            class="rollable rb-stat-roll-target"
            name="system.stats.intrepidity.final"
            value="{{system.stats.intrepidity.final}}"
            data-dtype="Number"
            data-roll="1d6 + @stats.intrepidity.final"
            data-label="Intrepidity"
            data-stat="intrepidity"
            readonly
          />
          <span class="rollable rb-stat-roll-target" data-roll="1d6 + @stats.intrepidity.final" data-label="Intrepidity" data-stat="intrepidity">INTREPIDITY</span>
        </div>
        <div class="rb-stat-row">
          <label>POTHER</label>
          <input type="text" name="system.stats.pother.sort" value="{{system.stats.pother.sort}}" data-dtype="Number" data-sort-drop-zone="true" />
          <span class="rb-stat-op">&plusmn;</span>
          <input type="text" name="system.stats.pother.peculiarity" value="{{system.stats.pother.peculiarity}}" data-dtype="Number" />
          <span class="rb-stat-op">+</span>
          <input type="text" name="system.stats.pother.elective" value="{{system.stats.pother.elective}}" data-dtype="Number" />
          <span class="rb-stat-op">=</span>
          <input
            type="text"
            class="rollable rb-stat-roll-target"
            name="system.stats.pother.final"
            value="{{system.stats.pother.final}}"
            data-dtype="Number"
            data-roll="1d6 + @stats.pother.final"
            data-label="Pother"
            data-stat="pother"
            readonly
          />
          <span class="rollable rb-stat-roll-target" data-roll="1d6 + @stats.pother.final" data-label="Pother" data-stat="pother">POTHER</span>
        </div>
        <div class="rb-stat-row">
          <label>SENSE</label>
          <input type="text" name="system.stats.sense.sort" value="{{system.stats.sense.sort}}" data-dtype="Number" data-sort-drop-zone="true" />
          <span class="rb-stat-op">&plusmn;</span>
          <input type="text" name="system.stats.sense.peculiarity" value="{{system.stats.sense.peculiarity}}" data-dtype="Number" />
          <span class="rb-stat-op">+</span>
          <input type="text" name="system.stats.sense.elective" value="{{system.stats.sense.elective}}" data-dtype="Number" />
          <span class="rb-stat-op">=</span>
          <input
            type="text"
            class="rollable rb-stat-roll-target"
            name="system.stats.sense.final"
            value="{{system.stats.sense.final}}"
            data-dtype="Number"
            data-roll="1d6 + @stats.sense.final"
            data-label="Sense"
            data-stat="sense"
            readonly
          />
          <span class="rollable rb-stat-roll-target" data-roll="1d6 + @stats.sense.final" data-label="Sense" data-stat="sense">SENSE</span>
        </div>
      </section>

      <section class="rb-panel rb-text-panel">
        <h3>Innate Peculiarities</h3>
        <div class="rb-feature-panel-header">
          <span class="rb-feature-drop-hint">Drop a Feature item here</span>
          <a class="item-control item-create" data-type="feature" data-category="innate" title="Add Innate Peculiarity">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        {{#if characterFeatures.innate.length}}
          <ol class="rb-feature-list">
            {{#each characterFeatures.innate as |item|}}
              <li class="item rb-feature-item" data-item-id="{{item._id}}">
                <div class="rb-feature-main">
                  <button type="button" class="rb-feature-toggle rb-feature-name">{{item.name}}</button>
                  <span class="rb-feature-controls">
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                <div class="rb-feature-description">
                  {{#if item.system.sheetDescription}}
                    {{item.system.sheetDescription}}
                  {{else}}
                    {{#if item.system.description}}
                      {{item.system.description}}
                    {{else}}
                      No description available.
                    {{/if}}
                  {{/if}}
                </div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <textarea name="system.innatePeculiarities">{{system.innatePeculiarities}}</textarea>
        {{/if}}
      </section>

      <section class="rb-panel rb-short-list">
        <h3>Personal Peculiarities</h3>
        <div class="rb-feature-panel-header">
          <span class="rb-feature-drop-hint">Drop a Feature item here</span>
          <a class="item-control item-create" data-type="feature" data-category="personal" title="Add Personal Peculiarity">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        {{#if characterFeatures.personal.length}}
          <ol class="rb-feature-list">
            {{#each characterFeatures.personal as |item|}}
              <li class="item rb-feature-item" data-item-id="{{item._id}}">
                <div class="rb-feature-main">
                  <button type="button" class="rb-feature-toggle rb-feature-name">{{item.name}}</button>
                  <span class="rb-feature-controls">
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                <div class="rb-feature-description">
                  {{#if item.system.description}}{{item.system.description}}{{else}}No description available.{{/if}}
                </div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <input type="text" name="system.personalPeculiarities.1" value="{{lookup system.personalPeculiarities '1'}}" placeholder="1" />
          <input type="text" name="system.personalPeculiarities.2" value="{{lookup system.personalPeculiarities '2'}}" placeholder="2" />
          <input type="text" name="system.personalPeculiarities.3" value="{{lookup system.personalPeculiarities '3'}}" placeholder="3" />
        {{/if}}
      </section>

      <section class="rb-panel rb-knacks">
        <h3>Knacks</h3>
        <div class="rb-feature-panel-header">
          <span class="rb-feature-drop-hint">Drop a Feature item here</span>
          <a class="item-control item-create" data-type="feature" data-category="knack" data-used-this-cycle="false" title="Add Knack">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        {{#if characterFeatures.knack.length}}
          <ol class="rb-feature-list">
            {{#each characterFeatures.knack as |item|}}
              <li class="item rb-feature-item rb-knack-item" data-item-id="{{item._id}}">
                <div class="rb-feature-main">
                  <label class="rb-feature-name rb-knack-name">
                    <input class="rb-knack-used" type="checkbox" data-item-id="{{item._id}}" {{checked item.system.usedThisCycle}} />
                    <button type="button" class="rb-feature-toggle rb-feature-name">{{item.name}}</button>
                  </label>
                  <span class="rb-feature-controls">
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                <div class="rb-feature-description">{{#if item.system.description}}{{item.system.description}}{{else}}No description available.{{/if}}</div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <div class="rb-knacks-note">Used this cycle?</div>
          <label><input type="checkbox" name="system.knacks.1" {{checked (lookup system.knacks '1')}} /> 1</label>
          <label><input type="checkbox" name="system.knacks.2" {{checked (lookup system.knacks '2')}} /> 2</label>
          <label><input type="checkbox" name="system.knacks.3" {{checked (lookup system.knacks '3')}} /> 3</label>
          <label><input type="checkbox" name="system.knacks.4" {{checked (lookup system.knacks '4')}} /> 4</label>
        {{/if}}
      </section>

      <section class="rb-panel rb-insufficiency">
        <h3>Insufficiencies</h3>
        <div class="rb-feature-panel-header">
          <span class="rb-feature-drop-hint">Drop a Feature item here</span>
          <a class="item-control item-create" data-type="feature" data-category="insufficiency" title="Add Insufficiency">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        {{#if characterFeatures.insufficiency.length}}
          <ol class="rb-feature-list">
            {{#each characterFeatures.insufficiency as |item|}}
              <li class="item rb-feature-item" data-item-id="{{item._id}}">
                <div class="rb-feature-main">
                  <button type="button" class="rb-feature-toggle rb-feature-name">{{item.name}}</button>
                  <span class="rb-feature-controls">
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                <div class="rb-feature-description">{{#if item.system.description}}{{item.system.description}}{{else}}No description available.{{/if}}</div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <input type="text" name="system.insufficiency" value="{{system.insufficiency}}" />
        {{/if}}
      </section>

      {{#if characterFeatures.uncategorized.length}}
        <section class="rb-panel rb-short-list">
          <h3>Uncategorized Features</h3>
          <div class="rb-knacks-note">Set each item's Category on its item sheet.</div>
          <ol class="rb-feature-list">
            {{#each characterFeatures.uncategorized as |item|}}
              <li class="item rb-feature-item" data-item-id="{{item._id}}">
                <div class="rb-feature-main">
                  <button type="button" class="rb-feature-toggle rb-feature-name">{{item.name}}</button>
                  <span class="rb-feature-controls">
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                <div class="rb-feature-description">{{#if item.system.description}}{{item.system.description}}{{else}}No description available.{{/if}}</div>
              </li>
            {{/each}}
          </ol>
        </section>
      {{/if}}
    </section>

    <section class="rb-column rb-right">
      <section class="rb-panel rb-relative">
        <h3>Appalling Relative</h3>
        <div class="rb-row rb-top-row">
          <label>Name</label>
          <input type="text" name="system.appallingRelative.name" value="{{system.appallingRelative.name}}" />
        </div>
        <div class="rb-row rb-subnote-row">
          <span></span>
          <input type="text" name="system.appallingRelative.titleOrHonorific" value="{{system.appallingRelative.titleOrHonorific}}" placeholder="title/honorific" />
        </div>
        <div class="rb-row rb-meta-row">
          <label>Sort</label>
          <input type="text" name="system.appallingRelative.sort" value="{{system.appallingRelative.sort}}" />
          <label>Pronouns</label>
          <input type="text" name="system.appallingRelative.pronouns" value="{{system.appallingRelative.pronouns}}" />
          <label>Age</label>
          <input type="text" name="system.appallingRelative.age" value="{{system.appallingRelative.age}}" />
        </div>
        <div class="rb-row rb-meta-row">
          <label>Relationship</label>
          <input type="text" name="system.appallingRelative.relationship" value="{{system.appallingRelative.relationship}}" />
          <label>On which side?</label>
          <input type="text" name="system.appallingRelative.whichSide" value="{{system.appallingRelative.whichSide}}" />
        </div>
        <div class="rb-compact-list">
          <label>Particulars</label>
          <input type="text" name="system.appallingRelative.particulars.1" value="{{lookup system.appallingRelative.particulars '1'}}" placeholder="1" />
          <input type="text" name="system.appallingRelative.particulars.2" value="{{lookup system.appallingRelative.particulars '2'}}" placeholder="2" />
          <input type="text" name="system.appallingRelative.particulars.3" value="{{lookup system.appallingRelative.particulars '3'}}" placeholder="3" />
        </div>
        <div class="rb-line-field">
          <label>Greatest weapon</label>
          <input type="text" name="system.greatestWeapon" value="{{system.greatestWeapon}}" />
        </div>
        <div class="rb-line-field">
          <label>Where do they drag you?</label>
          <input type="text" name="system.dragYou" value="{{system.dragYou}}" />
        </div>
        <div class="rb-line-field">
          <label>Home name, location, &amp; description</label>
          <input type="text" name="system.homeDescription" value="{{system.homeDescription}}" />
        </div>
        <div class="rb-grow-field">
          <label>Pets, community, interests, &amp; other notes</label>
          <textarea name="system.petsCommunityInterests">{{system.petsCommunityInterests}}</textarea>
        </div>
      </section>

      <section class="rb-panel rb-text-panel rb-family">
        <h3>Other Family &amp; Friends</h3>
        <textarea name="system.otherFamilyAndFriends">{{system.otherFamilyAndFriends}}</textarea>
      </section>

      <section class="rb-panel rb-text-panel rb-temp">
        <h3>Temporary Modifiers</h3>
        <textarea name="system.temporaryModifiers">{{system.temporaryModifiers}}</textarea>
      </section>
    </section>
  </section>

  <section class="riverbank-page-two">
    <section class="rb-page-two-grid">
      <section class="rb-panel rb-p2-home">
        <h3>Home</h3>
        <div class="rb-line-field">
          <label>Home name</label>
          <input type="text" name="system.home.name" value="{{system.home.name}}" />
        </div>
        <div class="rb-row rb-meta-row">
          <label>Home type</label>
          <input type="text" name="system.home.type" value="{{system.home.type}}" />
          <label>Size</label>
          <input type="text" name="system.home.size" value="{{system.home.size}}" />
        </div>
        <div class="rb-line-field">
          <label>Location</label>
          <input type="text" name="system.home.location" value="{{system.home.location}}" />
        </div>
        <div class="rb-line-field">
          <label>Housemate(s)?</label>
          <input type="text" name="system.home.housemates" value="{{system.home.housemates}}" />
        </div>
        <div class="rb-line-field">
          <label>The heart of your home</label>
          <input type="text" name="system.home.heart" value="{{system.home.heart}}" />
        </div>
        <div class="rb-grow-field">
          <label>Description</label>
          <textarea name="system.home.description">{{system.home.description}}</textarea>
        </div>
      </section>

      <section class="rb-panel rb-p2-souvenirs">
        <h3>Souvenirs</h3>
        <div class="rb-line-field">
          <label>Where do you display knick-knacks?</label>
          <input type="text" name="system.souvenirs.display" value="{{system.souvenirs.display}}" />
        </div>
        <div class="rb-grow-field">
          <label>What are they?</label>
          <textarea name="system.souvenirs.items">{{system.souvenirs.items}}</textarea>
        </div>
        <div class="rb-line-field">
          <label>Character-building tokens</label>
          <input type="text" name="system.souvenirs.tokens" value="{{system.souvenirs.tokens}}" />
        </div>
      </section>

      <section class="rb-panel rb-p2-pet">
        <h3>Pets</h3>
        <div class="rb-feature-panel-header">
          <span class="rb-feature-drop-hint">Drop a Pet here</span>
          <a class="item-control item-create" data-type="feature" data-category="pet" title="Add Pet">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        {{#if characterFeatures.pet.length}}
          <ol class="rb-feature-list">
            {{#each characterFeatures.pet as |item|}}
              <li class="item rb-feature-item" data-item-id="{{item._id}}">
                <div class="rb-feature-main">
                  <button type="button" class="rb-feature-toggle rb-feature-name">{{item.name}}</button>
                  <span class="rb-feature-controls">
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                <div class="rb-feature-description">
                  {{#if item.system.sheetDescription}}
                    {{{item.system.sheetDescription}}}
                  {{else}}
                    {{#if item.system.description}}
                      {{item.system.description}}
                    {{else}}
                      No description available.
                    {{/if}}
                  {{/if}}
                </div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <div class="rb-knacks-note">No pets added.</div>
        {{/if}}
      </section>

      <section class="rb-panel rb-p2-seasonal">
        <h3>Seasonal Reckoning</h3>
        <div class="rb-grow-field">
          <label>Personal goals, practical goals, &amp; timeframes</label>
          <textarea name="system.seasonalReckoning">{{system.seasonalReckoning}}</textarea>
        </div>
      </section>

      <section class="rb-panel rb-p2-vehicle">
        <h3>Vehicle?</h3>
        <div class="rb-yes-no">
          <label><input type="radio" name="system.vehicle.hasVehicle" value="true" data-dtype="Boolean" {{#if system.vehicle.hasVehicle}}checked{{/if}} /> Yes</label>
          <label><input type="radio" name="system.vehicle.hasVehicle" value="false" data-dtype="Boolean" {{#unless system.vehicle.hasVehicle}}checked{{/unless}} /> No</label>
        </div>
        <div class="rb-vehicle-types">
          <label><input type="checkbox" name="system.vehicle.types.bicycle" {{checked system.vehicle.types.bicycle}} /> bicycle</label>
          <label><input type="checkbox" name="system.vehicle.types.motorcycle" {{checked system.vehicle.types.motorcycle}} /> motor-cycle</label>
          <label><input type="checkbox" name="system.vehicle.types.rowingBoat" {{checked system.vehicle.types.rowingBoat}} /> rowing boat</label>
          <label><input type="checkbox" name="system.vehicle.types.sailboat" {{checked system.vehicle.types.sailboat}} /> sailboat</label>
          <label><input type="checkbox" name="system.vehicle.types.other" {{checked system.vehicle.types.other}} /> other</label>
          <input type="text" name="system.vehicle.types.otherText" value="{{system.vehicle.types.otherText}}" placeholder="other type" />
        </div>
        <div class="rb-grow-field">
          <label>Details</label>
          <textarea name="system.vehicle.details">{{system.vehicle.details}}</textarea>
        </div>
      </section>

      <section class="rb-panel rb-p2-notes">
        <h3>Other Notes</h3>
        <div class="rb-grow-field">
          <label>Clothing, hobbies, objects of desire, contents of your pockets, etc.</label>
          <textarea name="system.otherNotes">{{system.otherNotes}}</textarea>
        </div>
      </section>
    </section>
  </section>
</form>
