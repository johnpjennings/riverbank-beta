<form class="{{cssClass}} {{actor.type}} riverbank-sheet" autocomplete="off">
  <section class="rb-npc-statblock">
    <section class="rb-panel rb-top-id rb-npc-name-panel">
      <div class="rb-npc-top-row">
        <div class="rb-row">
          <label>Name</label>
          <input type="text" name="name" value="{{actor.name}}" />
        </div>
        <div class="rb-row">
          <label>Description</label>
          <input type="text" name="system.description" value="{{system.description}}" />
        </div>
      </div>
    </section>

    <section class="rb-npc-grid">
      {{#if isOrdinaryAnimalNpc}}
      <section class="rb-panel rb-text-panel rb-npc-box">
        <h3>Foe Level</h3>
        <textarea name="system.foeLevel">{{system.foeLevel}}</textarea>
      </section>
      <section class="rb-panel rb-text-panel rb-npc-box">
        <h3>Attitude</h3>
        <textarea name="system.attitude">{{system.attitude}}</textarea>
      </section>
      <section class="rb-panel rb-text-panel rb-npc-box">
        <h3>Size</h3>
        <textarea name="system.size">{{system.size}}</textarea>
      </section>
      <section class="rb-panel rb-text-panel rb-npc-box">
        <h3>Variety</h3>
        <textarea name="system.variety">{{system.variety}}</textarea>
      </section>
      <section class="rb-panel rb-text-panel rb-npc-box rb-npc-box--full">
        <h3>Notes</h3>
        <textarea name="system.notes">{{system.notes}}</textarea>
      </section>
      {{else}}
      <section class="rb-panel rb-text-panel rb-npc-box">
        <h3>Role</h3>
        <textarea name="system.role">{{system.role}}</textarea>
      </section>
      <section class="rb-panel rb-text-panel rb-npc-box">
        <h3>Foe Level</h3>
        <textarea name="system.foeLevel">{{system.foeLevel}}</textarea>
      </section>
      {{#if isAnimalNpc}}
      <section class="rb-panel rb-text-panel rb-npc-box rb-npc-box--full">
        <h3>Home Life</h3>
        <textarea name="system.homeLife">{{system.homeLife}}</textarea>
      </section>
      {{/if}}
      {{#if isHumanNpc}}
      <section class="rb-panel rb-text-panel rb-npc-box rb-npc-box--full">
        <h3>Attitude Toward Animals</h3>
        <textarea name="system.attitudeTowardAnimals">{{system.attitudeTowardAnimals}}</textarea>
      </section>
      {{/if}}
      <section class="rb-panel rb-text-panel rb-npc-box rb-npc-box--full">
        <h3>Particulars</h3>
        <textarea name="system.particulars">{{system.particulars}}</textarea>
      </section>
      <section class="rb-panel rb-text-panel rb-npc-box rb-npc-box--full">
        <h3>Notes</h3>
        <textarea name="system.notes">{{system.notes}}</textarea>
      </section>
      {{/if}}
    </section>
  </section>
</form>
